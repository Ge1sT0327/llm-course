# ============================================================
# 课程全局API配置 — 至少配置一个即可开始实验
# 将此文件复制为 .env 并填入你的 API Key
# ============================================================

# DeepSeek V4 (推荐, 性价比最高, 约1元/1M tokens)
# 注册: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云 Qwen3.7 (中文最强, 多模态)
# 注册: https://dashscope.aliyun.com
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 GLM-5.2 (Agent能力T0级)
# 注册: https://open.bigmodel.cn
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 月之暗面 Kimi K2.7 (256K超长上下文)
# 注册: https://platform.moonshot.cn
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 字节豆包 Seed 2.0 Pro (多模态最强)
# 注册: https://console.volcengine.com/ark
DOUBAO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
